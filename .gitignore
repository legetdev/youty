# On-device Core ML model weights (EmbeddingGemma + SigLIP) — NOT committed.
# Too large for a lean public repo and would burn the Git-LFS bandwidth quota.
# Published as a checksummed GitHub Release asset and fetched into Vendor/ via
# Scripts/fetch-models.sh. The tiny Manifest.json companions stay tracked so the
# .mlpackages reassemble. End users get these bundled inside the shipped DMG.
Vendor/embeddinggemma/models/**/*.bin
Vendor/embeddinggemma/models/**/*.mlmodel
Vendor/embeddinggemma/tokenizer/*.bin
Vendor/siglip/models/**/*.bin
Vendor/siglip/models/**/*.mlmodel

# EmbeddingGemma raw tokenizer source — 32 MB build input fetched from HuggingFace.
# The compact vocab/merges/added_tokens .bin artifacts ship in the models asset
# above (built by Scripts/build-gemma-tokenizer-artifact.py).
Vendor/embeddinggemma/tokenizer/tokenizer.json

# macOS
.DS_Store

# Secrets — never commit any of these.
# Defence-in-depth before Phase R (public repo).
.env
.env.*
*.key
*.pem
*.p12
secrets/
.secrets/
.gemini-api.key

