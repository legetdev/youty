<?xml version="1.0" encoding="utf-8"?>
<!--
    Youty Sparkle appcast feed — the source of truth for the auto-updater.

    Every shipped copy of Youty fetches this (every 24 h plus on-demand) from
    the URL in the app's Info.plist SUFeedURL key:
        https://youtyapp.vercel.app/appcast.xml
    It is served from the separate youty-web repo — keep this file and
    youty-web/public/appcast.xml in sync (copy this one over on each release).

    HOW TO CUT A NEW RELEASE
    1. ./Scripts/release-app.sh        # build + sign + notarize + staple .app
    2. ./Scripts/make-dmg.sh           # signed + notarized + stapled DMG
    3. ./Scripts/sparkle-sign-and-cut.sh build/Youty-<version>.dmg
                                       # prints a signed <item> block
    4. Add that <item> below (newest first), fill in the release notes.
    5. Upload the DMG to the GitHub Release tagged v<version>.
    6. Copy this file to youty-web/public/appcast.xml, push, let Vercel redeploy,
       then verify at https://youtyapp.vercel.app/appcast.xml.
-->
<rss version="2.0" xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle"
                  xmlns:dc="http://purl.org/dc/elements/1.1/">
    <channel>
        <title>Youty Updates</title>
        <link>https://youtyapp.vercel.app/appcast.xml</link>
        <description>Auto-update feed for Youty — macOS YouTube/Instagram/TikTok to-vault tool.</description>
        <language>en</language>

        <item>
            <title>Youty 1.0.0</title>
            <sparkle:version>1</sparkle:version>
            <sparkle:shortVersionString>1.0.0</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>26.0</sparkle:minimumSystemVersion>
            <pubDate>Mon, 15 Jun 2026 17:52:38 +0000</pubDate>
            <description><![CDATA[
                <h3>Youty 1.0.0 — initial public release</h3>
                <p>Turn YouTube, Instagram, and TikTok videos into a local,
                AI-readable knowledge base — 100% on-device.</p>
                <ul>
                    <li>Paste a URL for an instant transcript, or save the full
                    video as a Markdown + frame-snapshot bundle in a vault you own.</li>
                    <li>Search everything by meaning, on-device (EmbeddingGemma +
                    SigLIP). No API key, no account, no cloud, no telemetry.</li>
                    <li>Use it from the Mac app, the <code>youty</code> CLI, or any
                    MCP-compatible AI assistant.</li>
                </ul>
                <p>Requires macOS 26+ and Apple Silicon.</p>
            ]]></description>
            <enclosure
                url="https://github.com/legetdev/youty/releases/download/v1.0.0/Youty-1.0.0.dmg"
                sparkle:edSignature="fzbAnqKYSwUmtIoF7/lRE89DqnJeloUn1HVkVxNWckihVNEJBvE3Uu9lzJiUi7zpYgu3VSEXY+QCgXegKkmwDQ=="
                length="440304990"
                type="application/octet-stream"/>
        </item>
    </channel>
</rss>
