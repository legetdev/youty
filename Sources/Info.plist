<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>youty</string>
	<key>CFBundleIconFile</key>
	<string>AppIcon</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>youty</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSMinimumSystemVersion</key>
	<string>26.0</string>
	<key>NSHighResolutionCapable</key>
	<true/>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Youty transcribes the audio of saved Instagram and TikTok videos entirely on your device to produce timestamped captions in the vault note. Audio never leaves your Mac.</string>
	<!--
	  Sparkle auto-update configuration. The feed is hosted alongside the
	  landing page on Vercel; new release DMGs are signed with the EdDSA
	  private key held in the author's macOS Keychain (backup at
	  ~/.config/youty-sparkle/, never committed). Without a matching
	  signature, Sparkle refuses the update — so even if the appcast URL is
	  hijacked, an attacker cannot push a malicious binary.
	-->
	<key>SUFeedURL</key>
	<string>https://youtyapp.vercel.app/appcast.xml</string>
	<key>SUPublicEDKey</key>
	<string>YHWrchjvFb+EXxR0kFW+Cz51WwYrNmOKZrY908OGOVY=</string>
	<key>SUEnableAutomaticChecks</key>
	<true/>
	<key>SUEnableInstallerLauncherService</key>
	<false/>
	<key>SUScheduledCheckInterval</key>
	<integer>86400</integer>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>dev.leget.youty.url</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>youty</string>
			</array>
		</dict>
	</array>
	<key>NSServices</key>
	<array>
		<dict>
			<key>NSMenuItem</key>
			<dict>
				<key>default</key>
				<string>Save to Youty Vault</string>
			</dict>
			<key>NSMessage</key>
			<string>saveURLToYoutyVault</string>
			<key>NSPortName</key>
			<string>youty</string>
			<key>NSSendTypes</key>
			<array>
				<string>public.url</string>
				<string>public.plain-text</string>
				<string>NSStringPboardType</string>
			</array>
			<key>NSServiceDescription</key>
			<string>Save the selected URL to the Youty Vault.</string>
		</dict>
	</array>
</dict>
</plist>
